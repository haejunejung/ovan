{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter hoyst build",
    "test": "pnpm --filter hoyst test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build"
  },
  "devDependencies": {
    "jsdom": "^28.0.0",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "react-native": "0.81.5"
    },
    "onlyBuiltDependencies": [
      "es5-ext",
      "esbuild",
      "lefthook",
      "sharp"
    ]
  }
}
