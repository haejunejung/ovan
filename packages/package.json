{
  "name": "hoyst",
  "version": "0.0.0",
  "description": "Overlay library for React and React Native",
  "keywords": [
    "overlay",
    "react",
    "react-native",
    "teleport"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/web/index.js",
  "module": "./dist/web/index.js",
  "types": "./dist/web/index.d.ts",
  "exports": {
    ".": {
      "react-native": {
        "import": "./dist/native/index.js",
        "types": "./dist/native/index.d.ts"
      },
      "import": {
        "types": "./dist/web/index.d.ts",
        "default": "./dist/web/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "vitest dev"
  },
  "dependencies": {
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native-teleport": "^1.0.2",
    "release-it": "^19.2.4",
    "rolldown": "1.0.0-rc.9",
    "rolldown-plugin-dts": "^0.22.5",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^16.8 || ^17 || ^18 || ^19",
    "react-dom": "^16.8 || ^17 || ^18 || ^19",
    "react-native-teleport": ">=1.0.2"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-teleport": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2"
}
